<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Žádný cleartext traffic (HTTP) není povolen nikde -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Důvěřujeme pouze systémovým CA certifikátům, ne uživatelsky instalovaným -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
